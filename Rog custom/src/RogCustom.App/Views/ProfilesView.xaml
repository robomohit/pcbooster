<UserControl x:Class="RogCustom.App.Views.ProfilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel>
        <Border Background="{StaticResource ErrorBannerBrush}" Padding="14,10" Margin="0,0,0,16" CornerRadius="4"
                BorderBrush="{StaticResource AccentRedBrush}" BorderThickness="1,0,0,0"
                Visibility="{Binding LastError, Converter={StaticResource StringToVisibility}}">
            <TextBlock Foreground="{StaticResource ForegroundLightBrush}" TextWrapping="Wrap" Text="{Binding LastError}"/>
        </Border>

        <TextBlock Text="PROFILES" FontSize="11" FontWeight="Bold" Foreground="{StaticResource ForegroundDimBrush}" Margin="0,0,0,4"/>
        <TextBlock Text="Manage performance profiles" FontSize="16" FontWeight="Light" Foreground="{StaticResource ForegroundLightBrush}" Margin="0,0,0,20"/>

        <!-- Active Profile -->
        <TextBlock Text="ACTIVE PROFILE" FontSize="10" FontWeight="Bold" Foreground="{StaticResource ForegroundMutedBrush}" Margin="0,0,0,6"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <ComboBox ItemsSource="{Binding ProfileNames}"
                      SelectedItem="{Binding SelectedProfileName, Mode=TwoWay}"
                      MinWidth="220" Margin="0,0,10,0"/>
            <Button Content="DELETE" Padding="16,8" Click="DeleteProfile_Click"/>
        </StackPanel>

        <!-- New Profile -->
        <TextBlock Text="CREATE PROFILE" FontSize="10" FontWeight="Bold" Foreground="{StaticResource ForegroundMutedBrush}" Margin="0,0,0,6"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
            <TextBox Text="{Binding NewProfileName, UpdateSourceTrigger=PropertyChanged}" MinWidth="220" Margin="0,0,10,0"/>
            <Button Content="CREATE" Padding="16,8" Click="CreateProfile_Click"/>
        </StackPanel>

        <!-- Mode Details -->
        <TextBlock Text="MODE SETTINGS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource ForegroundMutedBrush}" Margin="0,0,0,8"/>
        <DataGrid ItemsSource="{Binding ModeDetails}" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,0,24"
                  MaxHeight="220">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mode" Binding="{Binding Mode}" Width="110"/>
                <DataGridTextColumn Header="Power Plan" Binding="{Binding PowerPlan}" Width="*"/>
                <DataGridTextColumn Header="CPU Boost" Binding="{Binding CpuBoost}" Width="100"/>
                <DataGridTextColumn Header="Fan Curve" Binding="{Binding FanCurve}" Width="100"/>
                <DataGridTextColumn Header="Core Park" Binding="{Binding CoreParking}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Power Plan Mapping -->
        <TextBlock Text="POWER PLAN MAPPING" FontSize="10" FontWeight="Bold" Foreground="{StaticResource ForegroundMutedBrush}" Margin="0,0,0,12"/>

        <Grid Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Silent" Foreground="{StaticResource ForegroundLightBrush}" VerticalAlignment="Center" Margin="0,0,0,8"/>
            <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding AvailablePlans}" DisplayMemberPath="FriendlyName"
                      SelectedValuePath="Guid" SelectedValue="{Binding SilentPlanGuid, Mode=TwoWay}" Margin="0,0,0,8"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Balanced" Foreground="{StaticResource ForegroundLightBrush}" VerticalAlignment="Center" Margin="0,0,0,8"/>
            <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding AvailablePlans}" DisplayMemberPath="FriendlyName"
                      SelectedValuePath="Guid" SelectedValue="{Binding BalancedPlanGuid, Mode=TwoWay}" Margin="0,0,0,8"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Performance" Foreground="{StaticResource ForegroundLightBrush}" VerticalAlignment="Center" Margin="0,0,0,8"/>
            <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding AvailablePlans}" DisplayMemberPath="FriendlyName"
                      SelectedValuePath="Guid" SelectedValue="{Binding PerformancePlanGuid, Mode=TwoWay}" Margin="0,0,0,8"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Turbo" Foreground="{StaticResource ForegroundLightBrush}" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="3" Grid.Column="1" ItemsSource="{Binding AvailablePlans}" DisplayMemberPath="FriendlyName"
                      SelectedValuePath="Guid" SelectedValue="{Binding TurboPlanGuid, Mode=TwoWay}"/>
        </Grid>

        <StackPanel Orientation="Horizontal">
            <Button Content="SAVE" Padding="20,10" Margin="0,0,10,0" Click="Save_Click"
                    BorderBrush="{StaticResource AccentBrush}"/>
            <Button Content="RESTORE DEFAULTS" Padding="20,10" Click="RestoreDefaults_Click"/>
        </StackPanel>
    </StackPanel>
    </ScrollViewer>
</UserControl>
