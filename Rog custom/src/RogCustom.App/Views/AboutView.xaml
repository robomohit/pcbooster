<UserControl x:Class="RogCustom.App.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel>
        <TextBlock Text="ABOUT" FontSize="11" FontWeight="Bold" Foreground="{StaticResource ForegroundDimBrush}" Margin="0,0,0,4"/>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="ROG" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
            <TextBlock Text="CUSTOM" FontSize="24" FontWeight="Light" Foreground="{StaticResource ForegroundLightBrush}" Margin="6,0,0,0"/>
            <TextBlock Text="{Binding Version}" FontSize="12" Foreground="{StaticResource ForegroundMutedBrush}"
                       VerticalAlignment="Bottom" Margin="12,0,0,4"/>
        </StackPanel>

        <Border Background="{StaticResource BackgroundCardBrush}" CornerRadius="4" Padding="16,14" Margin="0,0,0,24"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
            <TextBlock Text="{Binding Description}" Foreground="{StaticResource ForegroundLightBrush}" TextWrapping="Wrap" FontSize="12" LineHeight="20"/>
        </Border>

        <TextBlock Text="TROUBLESHOOTING" FontSize="10" FontWeight="Bold" Foreground="{StaticResource ForegroundMutedBrush}" Margin="0,0,0,8"/>
        <Border Background="{StaticResource BackgroundCardBrush}" CornerRadius="4" Padding="16,14"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
            <TextBlock Text="{Binding Troubleshooting}" Foreground="{StaticResource ForegroundLightBrush}" TextWrapping="Wrap"
                       FontFamily="Consolas" FontSize="11" LineHeight="18"/>
        </Border>
    </StackPanel>
    </ScrollViewer>
</UserControl>
