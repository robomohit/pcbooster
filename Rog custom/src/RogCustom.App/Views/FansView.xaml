<UserControl x:Class="RogCustom.App.Views.FansView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="StatusCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BackgroundCardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Margin" Value="0,0,10,10"/>
            <Setter Property="MinWidth" Value="170"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel>
        <Border Background="{StaticResource ErrorBannerBrush}" Padding="14,10" Margin="0,0,0,16" CornerRadius="4"
                BorderBrush="{StaticResource AccentRedBrush}" BorderThickness="1,0,0,0"
                Visibility="{Binding LastError, Converter={StaticResource StringToVisibility}}">
            <TextBlock Foreground="{StaticResource ForegroundLightBrush}" TextWrapping="Wrap" Text="{Binding LastError}"/>
        </Border>

        <TextBlock Text="FAN CONTROL" FontSize="11" FontWeight="Bold" Foreground="{StaticResource ForegroundDimBrush}" Margin="0,0,0,4"/>
        <TextBlock Text="FanControl (Rem0o) Integration" FontSize="16" FontWeight="Light" Foreground="{StaticResource ForegroundLightBrush}" Margin="0,0,0,20"/>

        <WrapPanel Margin="0,0,0,24">
            <Border Style="{StaticResource StatusCard}">
                <StackPanel>
                    <TextBlock Text="DETECTED" FontSize="10" Foreground="{StaticResource ForegroundMutedBrush}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding FanControlDetected}" FontSize="18" FontWeight="Light" Foreground="{StaticResource ForegroundLightBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatusCard}">
                <StackPanel>
                    <TextBlock Text="RUNNING" FontSize="10" Foreground="{StaticResource ForegroundMutedBrush}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding FanControlRunning}" FontSize="18" FontWeight="Light" Foreground="{StaticResource ForegroundLightBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatusCard}">
                <StackPanel>
                    <TextBlock Text="ACTIVE PROFILE" FontSize="10" Foreground="{StaticResource ForegroundMutedBrush}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding CurrentProfile}" FontSize="18" FontWeight="Light" Foreground="{StaticResource AccentBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <TextBlock Text="QUICK PROFILES" FontSize="11" FontWeight="Bold" Foreground="{StaticResource ForegroundDimBrush}" Margin="0,0,0,10"/>
        <WrapPanel Margin="0,0,0,24">
            <Button Content="QUIET" Padding="20,12" Margin="0,0,8,8" MinWidth="110" Click="QuietProfile_Click"/>
            <Button Content="NORMAL" Padding="20,12" Margin="0,0,8,8" MinWidth="110" Click="NormalProfile_Click"/>
            <Button Content="PERFORMANCE" Padding="20,12" Margin="0,0,8,8" MinWidth="110" Click="PerformanceProfile_Click"/>
            <Button Padding="20,12" Margin="0,0,8,8" MinWidth="110" Click="MaxProfile_Click"
                    BorderBrush="{StaticResource AccentRedBrush}">
                <TextBlock Text="MAX" Foreground="{StaticResource AccentRedBrush}" FontWeight="Bold"/>
            </Button>
        </WrapPanel>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="RESTORE DEFAULTS" Padding="16,10" Margin="0,0,8,0" Click="RestoreDefaults_Click"/>
            <Button Content="REFRESH" Padding="16,10" Click="Refresh_Click"/>
        </StackPanel>

        <Border Background="{StaticResource BackgroundCardBrush}" CornerRadius="4" Padding="16,12"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource ForegroundMutedBrush}" FontSize="11"
                       Text="Fan profiles are managed via FanControl (Rem0o). Place profile config files (quiet.json, normal.json, performance.json, max.json) in the FanControl installation directory. The app will swap configs and restart FanControl when applying profiles."/>
        </Border>
    </StackPanel>
    </ScrollViewer>
</UserControl>
