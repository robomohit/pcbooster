{
  "name": "rog-custom-frontend",
  "version": "1.0.0",
  "description": "Web frontend for Rog Custom hardware control application",
  "main": "index.html",
  "scripts": {
    "lint": "eslint script.js",
    "lint:fix": "eslint script.js --fix",
    "format": "prettier --write *.js *.css *.html",
    "serve": "python -m http.server 3000",
    "build": "echo 'Frontend is static, no build required'",
    "test": "echo 'No frontend tests configured yet'"
  },
  "devDependencies": {
    "eslint": "^8.50.0",
    "prettier": "^3.0.3",
    "@eslint/js": "^8.50.0"
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "es2022": true
    },
    "extends": [
      "eslint:recommended"
    ],
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    },
    "rules": {
      "no-console": "warn",
      "no-unused-vars": "error",
      "prefer-const": "error",
      "no-var": "error"
    }
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 2
  },
  "keywords": [
    "rog",
    "asus",
    "hardware",
    "monitoring",
    "control"
  ],
  "author": "Rog Custom Team",
  "license": "MIT"
}
